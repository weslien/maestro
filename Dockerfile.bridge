FROM golang:1.25-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /bridge ./cmd/bridge/

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /bridge /bridge
USER nonroot:nonroot
EXPOSE 8080
ENTRYPOINT ["/bridge"]
